{
  "openapi": "3.0.0",
  "info": {
    "title": "Scraper Go API",
    "version": "1.0.0",
    "description": "API mínima para disparar scrapes e gerenciar keywords"
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "paths": {
    "/scrape": {
      "post": {
        "summary": "Dispara um scrape agregando todas as fontes configuradas",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ScrapeRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Resultado do scrape",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ScrapeResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/keywords": {
      "get": {
        "summary": "Retorna keywords carregadas",
        "responses": {
          "200": {
            "description": "Lista de keywords",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "keywords": {
                      "type": "array",
                      "items": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Atualiza/persiste keywords",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "keywords": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Keywords enfileiradas/aceitas" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Job": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "company": { "type": "string" },
          "location": { "type": "string" },
          "url": { "type": "string" },
          "source": { "type": "string" },
          "sources": { "type": "array", "items": { "type": "string" } },
          "keyword": { "type": "string" },
          "keywords": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ScrapeRequest": {
        "type": "object",
        "properties": {
          "keywords": { "type": "array", "items": { "type": "string" } },
          "searchLocation": { "type": "string" },
          "searchGeoId": { "type": "string" },
          "searchLanguage": { "type": "string" },
          "jobTypes": { "type": "string" },
          "timeFilter": { "type": "string" },
          "remoteOnly": { "type": "boolean" },
          "resultsPerPage": { "type": "integer" },
          "maxPagesPerKeyword": { "type": "integer" },
          "waitBetweenSearchesMs": { "type": "integer" },
          "pageTimeoutMs": { "type": "integer" },
          "maxConcurrency": { "type": "integer" }
        },
        "required": ["keywords"]
      },
      "ScrapeResponse": {
        "type": "object",
        "properties": {
          "jobs": { "type": "array", "items": { "$ref": "#/components/schemas/Job" } },
          "total": { "type": "integer" },
          "cachedAt": { "type": "string", "format": "date-time" },
          "fromCache": { "type": "boolean" }
        }
      }
    }
  }
}
