{
  "name": "vagas-full-monorepo",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "scraper": "npm run scraper --workspace=backend",
    "scraper:watch": "npm run scraper:watch --workspace=backend",
    "test": "npm run test --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "validate": "npm run test --workspace=backend && npm run lint --workspace=frontend && npm run build --workspace=frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
