{
  "name": "vagas-full-monorepo",
  "version": "1.0.0",
  "description": "Aplicativo desktop para buscar e visualizar vagas com Electron, React e Node.js.",
  "author": "Bene Tesla Dev",
  "private": true,
  "main": "electron/main.js",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "prepare": "husky",
    "setup:dev": "npm ci && npm run prepare",
    "dev": "concurrently \"npm run dev --workspace=frontend\" \"npm run dev --workspace=backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "scraper": "npm run scraper --workspace=backend",
    "scraper:watch": "npm run scraper:watch --workspace=backend",
    "test": "npm run test --workspace=backend",
    "test:coverage": "npm run test:coverage --workspace=frontend && npm run test:coverage --workspace=backend",
    "build:frontend": "npm run build --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "validate": "npm run test --workspace=backend && npm run lint --workspace=frontend && npm run build --workspace=frontend",
    "electron": "electron .",
    "electron:dev": "npm run build:frontend && electron .",
    "dist": "npm run build:frontend && electron-builder",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "openid-client": "^6.8.4",
    "pdfkit": "^0.18.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "react-phone-number-input": "^3.4.17",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "tar": "^7.5.16",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@types/pino": "^7.0.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^42.3.3",
    "electron-builder": "^25.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "typescript": "^6.0.3"
  },
  "lint-staged": {
    "frontend/src/**/*.{js,jsx,ts,tsx}": [
      "npm exec --workspace=frontend eslint -- --max-warnings=0"
    ]
  },
  "build": {
    "appId": "com.benetesla.vagas-full",
    "productName": "Vagas Full",
    "asar": false,
    "files": [
      "electron/**/*",
      "backend/src/**/*",
      "backend/package.json",
      "frontend/dist/**/*",
      "!**/node_modules/.bin",
      "!**/*.{test,spec}.{js,ts}",
      "!**/tests/**",
      "!**/coverage/**"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist-electron"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vagas Full"
    }
  }
}
