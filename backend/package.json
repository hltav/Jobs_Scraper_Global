{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend para scraping e API de vagas do LinkedIn",
  "main": "index.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "NODE_ENV=development tsx src/server.ts",
    "scraper": "tsx index.ts",
    "scraper:watch": "nodemon index.ts",
    "api": "tsx src/server.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "validate": "npm test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "clear-cache": "tsx src/cache/clearCache.ts"
  },
  "keywords": [
    "linkedin",
    "jobs",
    "scraping",
    "http",
    "vagas",
    "emprego",
    "brasil",
    "tecnologia",
    "automation",
    "axios",
    "cheerio"
  ],
  "author": "Bene Tesla Dev",
  "license": "ISC",
  "dependencies": {
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "cheerio": "^1.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "iron-session": "^8.0.4",
    "pdfkit": "^0.18.0",
    "redis": "^5.12.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
